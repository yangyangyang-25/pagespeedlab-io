---
import { getCollection } from "astro:content";
import PostCard from "../../components/PostCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { groupByCategory, isPublished, slugify, sortPosts } from "../../lib/content";

export async function getStaticPaths() {
  const posts = sortPosts((await getCollection("posts")).filter(isPublished));
  const grouped = groupByCategory(posts);

  return Object.entries(grouped).map(([category, items]) => ({
    params: { category: slugify(category) },
    props: { category, items }
  }));
}

const { category, items } = Astro.props;
---

<BaseLayout
  title={category}
  description={`Posts filed under ${category}.`}
  pathname={`/category/${slugify(category)}/`}
>
  <section class="hero">
    <p class="meta">Category</p>
    <h1>{category}</h1>
  </section>
  <section class="post-list">
    {items.map((post) => <PostCard post={post} />)}
  </section>
</BaseLayout>
